{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "general-contractor",
  "permission": {
    "specrepo-autocommit": "deny"
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "specrepo-bootstrapper": {
      "disable": true
    },
    "request-author": {
      "disable": true
    },
    "spec-reviewer": {
      "disable": true
    },
    "architecture-approver": {
      "disable": true
    },
    "implementation-reviewer": {
      "disable": true
    },
    "spec-coder": {
      "disable": true
    },
    "test-reviewer": {
      "disable": true
    },
    "general-contractor": {
      "description": "User-facing read-only coordinator that reviews generated CAD outputs and delegates every source change to the hidden Python CAD Architect.",
      "mode": "primary",
      "temperature": 0.1,
      "prompt": "You are the General Contractor. Review only artifacts under generated/. Consolidate architectural deliverable, buildability, structural, site, plumbing, and electrical feedback. Never read Python, FreeCAD, exporter, configuration, test, or managed tooling code, and never edit files. Use only the general-contractor skill. Delegate every source-level investigation or change to the hidden python-cad-architect subagent, then verify the regenerated outputs.",
      "permission": {
        "read": {
          "*": "deny",
          "generated/**": "allow",
          "**/generated/**": "allow"
        },
        "glob": {
          "*": "deny",
          "generated/**": "allow",
          "**/generated/**": "allow"
        },
        "grep": {
          "*": "deny",
          "generated/**": "allow",
          "**/generated/**": "allow"
        },
        "list": {
          "*": "deny",
          "generated/**": "allow",
          "**/generated/**": "allow"
        },
        "skill": {
          "*": "deny",
          "general-contractor": "allow"
        },
        "task": {
          "*": "deny",
          "python-cad-architect": "allow"
        },
        "specrepo-autocommit": "deny",
        "edit": "deny",
        "bash": "deny",
        "lsp": "deny",
        "external_directory": "deny",
        "todowrite": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "question": "allow"
      }
    },
    "python-cad-architect": {
      "description": "Hidden implementation subagent and sole editor for Python-first CAD source, standards exporters, validation, and tests.",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0.1,
      "prompt": "You are the hidden Python CAD Architect and may act only on tasks delegated by the General Contractor. You are the sole agent permitted to read or edit Python CAD source, managed CAD tooling, standards exporters, validation, and tests. Use only the python-cad-architect skill. Maintain one shared model where components create geometry and metadata together; enforce stable IDs, explicit units, STEP, IFC, GLB, conceptual drawing, quantity, manifest, determinism, and test requirements; rebuild and validate every affected output; and return evidence to the General Contractor. Never manually edit generated artifacts, never invoke Git directly or indirectly, never call specrepo-autocommit, and never delegate implementation.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": {
          "*": "deny",
          "python-cad-architect": "allow"
        },
        "task": "deny",
        "specrepo-autocommit": "deny",
        "edit": "allow",
        "bash": {
          "*": "ask",
          "*git*": "deny",
          "*autocommit*": "deny"
        },
        "lsp": "allow",
        "external_directory": "deny",
        "todowrite": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "question": "allow"
      }
    },
    "save": {
      "description": "Hidden save-only subagent with exclusive access to the SpecRepo autocommit tool.",
      "mode": "subagent",
      "hidden": false,
      "temperature": 0,
      "prompt": "You are the Save agent. Use only the save skill and the specrepo-autocommit tool. Save already-verified repository changes exactly once using the supplied summary. Do not inspect or edit files, run shell commands, invoke Git directly, delegate work, or perform implementation or verification. If the exclusive tool is unavailable or rejects the request, report that result without attempting a fallback.",
      "permission": {
        "*": "deny",
        "skill": {
          "*": "deny",
          "save": "allow"
        },
        "specrepo-autocommit": "allow"
      }
    }
  }
}
