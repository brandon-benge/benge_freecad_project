{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "benge-design-maintainer",
  "permission": {
    "specrepo-autocommit": "deny"
  },
  "agent": {
    "plan": { "disable": true },
    "build": { "disable": true },
    "specrepo-bootstrapper": { "disable": true },
    "request-author": { "disable": true },
    "spec-reviewer": { "disable": true },
    "architecture-approver": { "disable": true },
    "implementation-reviewer": { "disable": true },
    "spec-coder": { "disable": true },
    "test-reviewer": { "disable": true },
    "benge-design-maintainer": {
      "description": "Design and CAD source maintainer. Edits config.py, model.py, drawing_annotations.py, and tests/ using public installed python_cad_tools API.",
      "mode": "primary",
      "temperature": 0.1,
      "prompt": "You are the Benge Design Maintainer. Edit only config.py, model.py, drawing_annotations.py, and tests/. Use only the documented public python_cad_tools API. Never read or patch tooling source or site-packages. Preserve stable complex.* element IDs. Run python-cad build and the test suite after changes. Never invoke Git or specrepo-autocommit.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": { "*": "deny", "benge-design-maintainer": "allow" },
        "task": "deny",
        "specrepo-autocommit": "deny",
        "edit": "allow",
        "bash": "allow",
        "lsp": "allow",
        "external_directory": "ask",
        "todowrite": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "question": "allow"
      }
    },
    "benge-project-operations": {
      "description": "Repository and project operations. Maintains pyproject.toml, locks, README, AGENTS.md, .github/workflows, .gitignore, and agent integration.",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0.1,
      "prompt": "You are the Benge Project Operations agent. Edit pyproject.toml, requirements/locks, README, AGENTS.md, .agents/, .claude/, .codex/, .opencode/, opencode.jsonc, CLAUDE.md, .github/workflows/, .gitignore, and migration docs. Do not change CAD geometry, element IDs, model structure, or annotation content. Never invoke Git or specrepo-autocommit.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": { "*": "deny", "benge-project-operations": "allow" },
        "task": "deny",
        "specrepo-autocommit": "deny",
        "edit": "allow",
        "bash": "allow",
        "lsp": "allow",
        "external_directory": "ask",
        "todowrite": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "question": "allow"
      }
    },
    "benge-artifact-reviewer": {
      "description": "Read-only reviewer of generated CAD artifacts, manifests, drawings, and site content.",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0.1,
      "prompt": "You are the Benge Artifact Reviewer. Review only artifacts under generated/. Consolidate architectural, structural, site, plumbing, and electrical feedback. Never read Python, test, configuration, or governance source. Never edit files. Delegate source changes to benge-design-maintainer.",
      "permission": {
        "read": { "*": "deny", "generated/**": "allow", "**/generated/**": "allow" },
        "glob": { "*": "deny", "generated/**": "allow", "**/generated/**": "allow" },
        "grep": { "*": "deny", "generated/**": "allow", "**/generated/**": "allow" },
        "list": { "*": "deny", "generated/**": "allow", "**/generated/**": "allow" },
        "skill": { "*": "deny", "benge-artifact-reviewer": "allow" },
        "task": { "*": "deny", "benge-design-maintainer": "allow" },
        "specrepo-autocommit": "deny",
        "edit": "deny",
        "bash": "allow",
        "lsp": "deny",
        "external_directory": "deny",
        "todowrite": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "question": "allow"
      }
    },
    "cad-compatibility-verifier": {
      "description": "Independent read-only verifier. Installs exact package, runs full matrix, emits compatibility report.",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0,
      "prompt": "You are the CAD Compatibility Verifier. Create temporary environments, install the exact pinned python-cad-tools, and run Ruff/mypy/pytest/python-cad commands. Produce a machine-readable report. Never edit source, fix failures, or ask the user to test.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": { "*": "deny", "cad-compatibility-verifier": "allow" },
        "task": "deny",
        "specrepo-autocommit": "deny",
        "edit": "deny",
        "bash": "allow",
        "lsp": "deny",
        "external_directory": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow"
      }
    },
    "save": {
      "description": "Hidden save-only subagent with exclusive access to the specrepo-autocommit tool.",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0,
      "prompt": "You are the Save agent. Use only the save skill and the specrepo-autocommit tool. Save already-verified repository changes exactly once using the supplied summary. Do not inspect or edit files, run shell commands, invoke Git, delegate work, or perform implementation or verification.",
      "permission": {
        "*": "deny",
        "skill": { "*": "deny", "save": "allow" },
        "specrepo-autocommit": "allow"
      }
    }
  }
}
